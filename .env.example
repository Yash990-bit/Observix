# ==========================================
# AEGIS AI - ENVIRONMENT TEMPLATE
# ==========================================

# Application Environment (development | production)
PORT=3000
NODE_ENV=development

# ------------------------------------------
# PostgreSQL Database
# Local Dev: postgresql://aegis:aegispass@localhost:5432/aegis
# Production: postgresql://<USER>:<PASS>@<AWS_RDS_HOST>:5432/<DB_NAME>?sslmode=require
# ------------------------------------------
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegispass
POSTGRES_DB=aegis
DATABASE_URL=postgresql://aegis:aegispass@localhost:5432/aegis

# ------------------------------------------
# Redis Cluster
# Local Dev: redis://localhost:6379
# Production: rediss://:<PASS>@<ELASTICACHE_HOST>:6379
# ------------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------------
# ClickHouse OLAP Engine
# Local Dev: http://localhost:8123
# Production: https://<CLICKHOUSE_CLOUD_HOST>:8443
# ------------------------------------------
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_USER=aegis
CLICKHOUSE_PASSWORD=aegispass
CLICKHOUSE_DATABASE=aegis

# ------------------------------------------
# NATS JetStream Message Backbone
# Local Dev: nats://localhost:4222
# Production: nats://<USER>:<PASS>@<NATS_CLUSTER_HOST>:4222
# ------------------------------------------
NATS_URL=nats://localhost:4222
